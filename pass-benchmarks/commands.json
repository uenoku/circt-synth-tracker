        "circt": "synth-generic-lut-mapper{max-lut-size={lut-k} max-cuts-per-root={lut-max-cut-size}}"
    },
    {
        "name": "sop-balancing",
        "abc": "if -K {lut-k} -C {lut-max-cut-size} -g",
